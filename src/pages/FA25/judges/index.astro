---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import semesterMeta from "../../../../data/semesters/FA25/semester.json";
import judges from "../../../../data/semesters/FA25/judges.json";
---
<BaseLayout title={`${semesterMeta.title} Judges`}>
  <section class="hero">
    <div class="shell">
      <div class="hero-card">
        <p class="eyebrow">{semesterMeta.code}</p>
        <h1>Judges</h1>
        <p class="lede">Current public listing. We can later decide whether individual assignments remain public, semi-public, or private-by-link.</p>
      </div>
    </div>
  </section>
  <section class="shell">
    <div class="panel">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Role</th>
            <th>Assignments</th>
          </tr>
        </thead>
        <tbody>
          {judges.map((judge) => (
            <tr>
              <td><a href={`/FA25/judges/${encodeURIComponent(judge.name)}/`}>{judge.name}</a></td>
              <td>{judge.jobTitle}{judge.company ? ` · ${judge.company}` : ""}</td>
              <td>{judge.slots.map((slot) => `${slot.time}: ${slot.degreeProgram}: ${slot.projectTitle}`).join(" | ")}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
