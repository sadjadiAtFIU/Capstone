---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "FIU Capstone Showcase for historical and current semesters."
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        --bg: #f6f3ec;
        --surface: rgba(255, 255, 255, 0.9);
        --surface-strong: #ffffff;
        --ink: #14213d;
        --muted: #4f5d75;
        --accent: #0d5c63;
        --accent-2: #c38b2f;
        --line: rgba(20, 33, 61, 0.14);
        --shadow: 0 24px 70px rgba(20, 33, 61, 0.12);
        --radius: 24px;
        --max: 1180px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(195, 139, 47, 0.16), transparent 30%),
          radial-gradient(circle at top right, rgba(13, 92, 99, 0.14), transparent 24%),
          linear-gradient(180deg, #f1ece2 0%, var(--bg) 38%, #fbfaf7 100%);
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(calc(100% - 2rem), var(--max));
        margin: 0 auto;
      }

      .hero {
        padding: 4rem 0 2rem;
      }

      .hero-card,
      .panel {
        background: var(--surface);
        backdrop-filter: blur(10px);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }

      .hero-card {
        padding: 2rem;
      }

      .eyebrow {
        font-size: 0.82rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin: 0 0 1rem;
      }

      h1, h2, h3 {
        line-height: 1.05;
        margin: 0;
      }

      h1 {
        font-size: clamp(2.6rem, 7vw, 5.8rem);
        max-width: 10ch;
      }

      h2 {
        font-size: clamp(1.8rem, 4vw, 3rem);
      }

      p {
        line-height: 1.6;
      }

      .lede {
        max-width: 60ch;
        color: var(--muted);
        font-size: 1.05rem;
      }

      .grid {
        display: grid;
        gap: 1.25rem;
      }

      .cards {
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      }

      .panel {
        padding: 1.25rem;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.35rem 0.8rem;
        background: var(--surface-strong);
        font-size: 0.92rem;
      }

      .semester-list {
        display: grid;
        gap: 1rem;
      }

      .semester-card {
        display: grid;
        gap: 0.9rem;
        padding: 1.25rem;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.82);
        text-decoration: none;
      }

      .semester-card:hover {
        transform: translateY(-2px);
        transition: transform 160ms ease;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.8rem;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        border: 1px solid transparent;
        background: var(--ink);
        color: white;
        text-decoration: none;
      }

      .button.secondary {
        background: transparent;
        border-color: var(--line);
        color: var(--ink);
      }

      header.site-nav {
        padding: 1rem 0 0;
      }

      header.site-nav .shell {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand {
        font-size: 0.95rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
      }

      main {
        padding-bottom: 4rem;
      }

      footer {
        padding: 2rem 0 4rem;
        color: var(--muted);
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th, td {
        padding: 0.9rem;
        vertical-align: top;
        border-bottom: 1px solid var(--line);
      }

      @media (max-width: 720px) {
        .hero-card {
          padding: 1.25rem;
        }

        h1 {
          max-width: none;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-nav">
      <div class="shell">
        <a class="brand" href="/">FIU Capstone Showcase</a>
        <div class="actions">
          <a class="button secondary" href="/#semesters">Semesters</a>
          <a class="button secondary" href="/#process">Process</a>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="shell">
        Built for long-term semester publishing and historical archiving.
      </div>
    </footer>
  </body>
</html>
